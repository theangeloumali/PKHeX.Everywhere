@page "/items"
@using PKHeX.Facade.Repositories
@using PKHeX.Web.Plugins
@using PKHeX.Web.Services.Plugins

<Flex Direction="FlexDirection.Vertical" Style="width: 100%;gap: 20px;">
    <PageHeader BackIcon="true" Style="max-width: 100%">
        <TitleTemplate>Items</TitleTemplate>

        <PageHeaderExtra>
            <Space Wrap>
                <SpaceItem>
                    <Button Type="ButtonType.Primary" Icon="plus" OnClick="OnAddItemClick">
                        Add one item
                    </Button>
                </SpaceItem>
                <SpaceItem>
                    <Button Type="ButtonType.Default" Icon="appstore-add" OnClick="() => ShowFillConfirmation(InventoryFillMode.StandardItems)">
                        Add all supported items
                    </Button>
                </SpaceItem>
                @if (Inventories?.HasSupportedKeyItems is true)
                {
                    <SpaceItem>
                        <Button Type="ButtonType.Default" Icon="key" OnClick="() => ShowFillConfirmation(InventoryFillMode.KeyItems)">
                            Add supported key items
                        </Button>
                    </SpaceItem>
                }
            </Space>
        </PageHeaderExtra>
    </PageHeader>

    <Tabs @bind-ActiveKey="@_activeKey" DefaultActiveKey="@DefaultActiveKey" Class="tab-scrollable" Animated>
        @foreach (var inventoryType in InventoryTypes)
        {
            <TabPane Tab="@inventoryType" Key="@inventoryType">
                <ItemsTable
                    @key="@inventoryType"
                    Inventory="Inventories?[inventoryType]"
                    DataSource="@(Inventories?[inventoryType].Where(i => i.Definition.Id != ItemDefinition.None).ToList())"/>
            </TabPane>
        }
    </Tabs>
</Flex>

@if (ActiveInventory is not null)
{
    <AddItemModal
        @bind-Visible="@_addItemModalVisible"
        TargetInventory="ActiveInventory"
        OnOk="@HandleOk"
        OnCancel="@HandleCancel"/>
}

<Modal
    Title="@FillConfirmationTitle"
    @bind-Visible="_fillConfirmationVisible"
    OnOk="HandleFillItems"
    OnCancel="HideFillConfirmation">
    @if (_pendingFillMode is InventoryFillMode.KeyItems)
    {
        <Paragraph>
            Key items can affect story progression and may not agree with the save's event flags.
            This fills only supported key items. Existing key-item quantities will be replaced.
        </Paragraph>
    }
    else
    {
        <Paragraph>
            This fills every supported item except key items, including TM/HM pouches, to each pouch maximum.
            Existing quantities will be replaced. Cramped pouches may not fit every supported item.
        </Paragraph>
    }
</Modal>

@code {
    [Inject] public required PlugInRuntime PlugInRuntime { get; set; }
    [Inject] public required GameService GameService { get; set; }
    [Inject] public required AnalyticsService Analytics { get; set; }
    [Inject] public required INotificationService Notification { get; set; }

    string? _activeKey;

    Inventories? Inventories => GameService.Game?.Trainer.Inventories;
    Inventory? ActiveInventory => string.IsNullOrWhiteSpace(_activeKey) ? null : Inventories?[_activeKey];
    string[] InventoryTypes => Inventories?.InventoryTypes.OrderBy(t => t).ToArray() ?? [];
    string? DefaultActiveKey => InventoryTypes.FirstOrDefault();
    string FillConfirmationTitle => _pendingFillMode is InventoryFillMode.KeyItems
        ? "Add supported key items?"
        : "Add all supported items?";

    #region Add Item Modal

    bool _addItemModalVisible;
    bool _fillConfirmationVisible;
    InventoryFillMode _pendingFillMode;

    Task OnAddItemClick()
    {
        _addItemModalVisible = true;
        return Task.CompletedTask;
    }

    async Task HandleOk(AddItemModal.ItemToBeAdded itemToBeAdded)
    {
        if (ActiveInventory is null) return;
        ActiveInventory?.Set(itemToBeAdded.Id, itemToBeAdded.Count);

        await PlugInRuntime.RunAll<IRunOnItemChanged>(h => h.OnItemChanged(new(itemToBeAdded.Id, itemToBeAdded.Count)));
        _addItemModalVisible = false;

        Track(itemToBeAdded);
        
        StateHasChanged();
        ShouldRender();
    }

    private void Track(AddItemModal.ItemToBeAdded itemToBeAdded)
    {
        Analytics.TrackItemModified(itemToBeAdded);
    }

    private void HandleCancel()
    {
        _addItemModalVisible = false;
    }

    private Task ShowFillConfirmation(InventoryFillMode fillMode)
    {
        _pendingFillMode = fillMode;
        _fillConfirmationVisible = true;
        return Task.CompletedTask;
    }

    private Task HideFillConfirmation()
    {
        _fillConfirmationVisible = false;
        return Task.CompletedTask;
    }

    private async Task HandleFillItems()
    {
        if (Inventories is null) return;

        var isKeyItemFill = _pendingFillMode is InventoryFillMode.KeyItems;
        var fillSummary = isKeyItemFill
            ? Inventories.SetSupportedKeyItemsToMax()
            : Inventories.SetAllSupportedToMax();
        foreach (var inventory in Inventories.InventoryItems.Values)
        {
            foreach (var item in inventory.AllExceptNone())
                await PlugInRuntime.RunAll<IRunOnItemChanged>(hook => hook.OnItemChanged(new(item.Id, (uint)item.Count)));
        }

        _fillConfirmationVisible = false;
        _ = Notification.Open(new NotificationConfig
        {
            Message = isKeyItemFill ? "Supported key items added" : "Supported items added",
            Description = fillSummary.SkippedItemCount == 0
                ? $"Filled all {fillSummary.AddedItemCount} supported {(isKeyItemFill ? "key-item" : "item")} slots."
                : $"Filled {fillSummary.AddedItemCount} of {fillSummary.RequestedItemCount} supported item slots; {fillSummary.SkippedItemCount} did not fit in cramped pouches.",
            NotificationType = fillSummary.SkippedItemCount == 0
                ? NotificationType.Success
                : NotificationType.Warning,
        });
        StateHasChanged();
    }

    enum InventoryFillMode
    {
        StandardItems,
        KeyItems,
    }

    #endregion

}
